# Environment Variables for MeowNet
# Copy to .env.local and fill in values

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role — NEVER expose to client. Used in server actions and API routes only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Clerk ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key-here
CLERK_SECRET_KEY=your-clerk-secret-key-here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/signup
CLERK_TELEMETRY_DISABLED=1

# ── Python ML Service ─────────────────────────────────────────────────────────
# URL of the FastAPI ML service (Render / local)
ML_SERVICE_URL=http://localhost:8000

# Shared secret between Next.js and ML service
ML_SERVICE_SECRET=change-me-in-production-use-long-random-string

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Used by the Python ML service to call HuggingFace Inference API
# Set in Render environment, NOT in .env.local
HUGGINGFACE_API_KEY=hf_your_key_here

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Tenor GIF Search API key
TENOR_API_KEY=your-tenor-api-key-here
